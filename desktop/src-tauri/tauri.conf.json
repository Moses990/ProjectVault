{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Vault",
  "version": "0.1.0",
  "identifier": "com.projectvault.desktop",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../../frontend/out"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "externalBin": ["binaries/project-vault-backend"],
    "windows": {
      "webviewInstallMode": {
        "type": "fixedRuntime",
        "path": "binaries/webview2-fixed-runtime/Microsoft.WebView2.FixedVersionRuntime.149.0.4022.96.x64"
      }
    }
  }
}
